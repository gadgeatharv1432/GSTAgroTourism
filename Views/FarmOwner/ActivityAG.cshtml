                        messageTop: function () {
                            return 'Downloaded: ' + getExportDateTime();
                        },
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4, 5, 6, 7, 8],
                            rows: function (idx, data, node) {
                                return $(node).find('.rowCheckbox').prop('checked');
                            },
                            format: {
                                body: function (data, row, column, node) {
                                    if (column === 1) { 

                                        exportRowIndex++;
                                        return exportRowIndex.toString();
                                    }
                                    return $(node).text().trim();
                                }
                            }
                        },
                        customize: function () {
                            exportRowIndex = 0;
                        }
                    },
// PRINT
                    {
                        extend: 'print',
