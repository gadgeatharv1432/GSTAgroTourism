@model  List<AgroClassLib.FarmOwner.FarmActivitiesAG>

@{
    ViewBag.Title = "ActivityAG";
    Layout = "~/Views/Shared/FarmOwner.cshtml";
}
<style>
    #editActivityModal .modal-content {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .form-error {
        color: #dc3545;
        font-size: 13px;
        margin-top: 4px;
    }

    .input-error {
        border: 2px solid #dc3545 !important;
    }

    .input-valid {
        border: 2px solid #28a745 !important;
    }
</style>

<!-- Button to open Add Activity modal -->
<button class="btn btn-success" onclick="OpenAddModal()">
    + Add Activity
</button>


<!-- Activity Data Table -->
<table id="dataTable"
       class="table table-hover table-striped"
       style="width:100%">

    <thead>
        <tr>
            <th>Sr No.</th>
            <th>Farmhouse</th>
            <th>Name</th>
            <th>Duration</th>
            <th>Price</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Description</th>
            <th>Image</th>
            <th>Status</th>
            <th style="width:150px;">Action</th>
        </tr>
    </thead>

    <tbody>
        @{ int sr = 1; }

        @foreach (var item in Model)
        {
            <tr>

                <td>@sr</td>

                <td>@item.FarmHouseName</td>

                <td>@item.ActivityName</td>

                <td>@item.Duration</td>

                <td>@item.Price</td>

                <td>@(item.StartDate?.ToString("yyyy-MM-dd"))</td>

                <td>@(item.EndDate?.ToString("yyyy-MM-dd"))</td>

                <td>@item.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" style="width:80px;height:55px;object-fit:cover;border-radius:6px;">
                    }
                </td>

                <td>
                    <input type="checkbox"
                           onchange="ToggleStatus(@item.ActivityId,this.checked)"
                           @(item.IsActive ? "checked" : "") />
                </td>

                <td>
                    <div style="display:flex;gap:6px;justify-content:center;white-space:nowrap;">

                        <button class="btn btn-sm btn-primary"
                                onclick="EditActivity(@item.ActivityId)">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-danger"
                                onclick="DeleteActivity(@item.ActivityId)">
                            Delete
                        </button>

                    </div>
                </td>

            </tr>
            sr++;
        }

    </tbody>

</table>

<!-- Add Activity Modal -->
<div id="addActivityModal" class="modal fade">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header text-bg-success text-white">
                <h5 class="modal-title">Add Activity</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="container-fluid">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Farmhouse</label>
                        <div class="col-sm-8">

                            @Html.DropDownList(
                             "FarmHouseCode",
                             (List<SelectListItem>)ViewBag.FarmHouseList,
                             "-- Select Farmhouse --",
                             new { @class = "form-control", id = "FarmHouseCode" }
                         )

                            <div id="FarmHouseCodeError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Start Date</label>
                        <div class="col-sm-8">
                            <input type="date"
                                   id="StartDate"
                                   class="form-control">

                            <div id="StartDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">End Date</label>
                        <div class="col-sm-8">
                            <input type="date"
                                   id="EndDate"
                                   class="form-control">

                            <div id="EndDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Name</label>
                        <div class="col-sm-8">

                            <input type="text"
                                   id="ActivityName"
                                   class="form-control"
                                   placeholder="Enter activity name"
                                   pattern="^[A-Za-z\s]+$"
                                   oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'')">

                            <div id="ActivityNameError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Duration</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="Duration"
                                   class="form-control"
                                   placeholder="Example: 2 Hours"
                                   pattern="^[0-9A-Za-z\s]+$"
                                   title="Only numbers and letters allowed">
                            <div id="DurationError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Price</label>
                        <div class="col-sm-8">
                            <input type="number"
                                   id="Price"
                                   class="form-control"
                                   placeholder="Enter price"
                                   min="1"
                                   step="0.01">
                            <div id="PriceError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Description</label>
                        <div class="col-sm-8">
                            <textarea id="Description"
                                      rows="3"
                                      maxlength="250"
                                      class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Image</label>
                        <div class="col-sm-8">
                            <input type="file" id="ActivityImage" class="form-control" accept=".jpg,.jpeg,.png">
                            <img id="PreviewImage" style="width:90px;height:60px;display:none;border-radius:5px;margin-top:10px;">
                        </div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success px-4"
                        onclick="SaveActivity()">
                    Save
                </button>

                <button class="btn btn-secondary px-4"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

            </div>

        </div>
    </div>
</div>


<!-- Edit Activity Modal -->
<div id="editActivityModal" class="modal fade">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header text-bg-warning text-black">
                <h5 class="modal-title">Edit Activity</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="container-fluid">

                    <input type="hidden" id="EditActivityId">
                    <input type="hidden" id="EditActivityCode">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Farmhouse</label>
                        <div class="col-sm-8">

                            @Html.DropDownList(
                                "EditFarmHouseCode",
                                (List<SelectListItem>)ViewBag.FarmHouseList,
                                "-- Select Farmhouse --",
                                new { @class = "form-control", id = "EditFarmHouseCode" }
                            )
                            <div id="EditFarmHouseCodeError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Start Date</label>
                        <div class="col-sm-8">
                            <input type="date" id="EditStartDate" class="form-control">

                            <div id="EditStartDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">End Date</label>
                        <div class="col-sm-8">
                            <input type="date" id="EditEndDate" class="form-control">

                            <div id="EditEndDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Name</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="EditActivityName"
                                   class="form-control"
                                   pattern="^[A-Za-z\s]+$"
                                   oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'')">
                            <div id="EditActivityNameError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Duration</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="EditDuration"
                                   class="form-control"
                                   pattern="^[0-9A-Za-z\s]+$">
                            <div id="EditDurationError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Price</label>
                        <div class="col-sm-8">
                            <input type="number"
                                   id="EditPrice"
                                   class="form-control"
                                   min="1"
                                   step="0.01">
                            <div id="EditPriceError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Description</label>
                        <div class="col-sm-8">
                            <textarea id="EditDescription"
                                      rows="3"
                                      maxlength="250"
                                      class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Image</label>
                        <div class="col-sm-8">
                            <input class="form-control" type="file" id="EditImage" accept=".jpg,.jpeg,.png">
                            <br />
                            <img id="EditPreviewImage" style="width:90px;height:60px;display:none;border-radius:5px;object-fit:cover;" />
                        </div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success px-4"
                        onclick="UpdateActivity()">
                    Update
                </button>

                <button class="btn btn-secondary px-4"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

            </div>

        </div>
    </div>
</div>

@section scripts{

    <!-- ============================================= -->
    <!--            ACTIVITY MANAGEMENT SCRIPTS        -->
    <!-- ============================================= -->

    <script>
        // Utility function for displaying SweetAlert notifications
        function ShowAlert(type, title, message, reload = false) {

            Swal.fire({
                icon: type,
                title: title,
                text: message,
                confirmButtonColor: "#27ae60"
            }).then(() => {

                if (reload)
                    location.reload();
            });
        }
    </script>
    <script>
        // Opens Add Activity modal and resets all form fields
        function OpenAddModal() {

            $("#StartDate").val("");
            $("#EndDate").val("");
            $("#ActivityName").val("");
            $("#Duration").val("");
            $("#Price").val("");
            $("#Description").val("");
            $("#ActivityImage").val("");

            $(".form-control").removeClass("input-error input-valid");
            $(".form-error").text("");

            const modal = new bootstrap.Modal(document.getElementById('addActivityModal'));
            modal.show();
        }
    </script>

    <script>

        function setError(inputId, message) {
            $("#" + inputId).removeClass("input-valid").addClass("input-error");
            $("#" + inputId + "Error").text(message);
        }

        function setValid(inputId) {
            $("#" + inputId).removeClass("input-error").addClass("input-valid");
            $("#" + inputId + "Error").text("");
        }
        // Saves new activity using AJAX call
        function SaveActivity() {

            let isValid = true;

            let farm = $("#FarmHouseCode").val();
            let name = $("#ActivityName").val().trim();
            let duration = $("#Duration").val().trim();
            let price = $("#Price").val();
            let start = $("#StartDate").val();
            let end = $("#EndDate").val();

            if (!farm) {
                setError("FarmHouseCode", "Please select farmhouse");
                isValid = false;
            }
            else setValid("FarmHouseCode");


            if (!name) {
                setError("ActivityName", "Activity name required");
                isValid = false;
            }
            else setValid("ActivityName");


            if (!duration) {
                setError("Duration", "Duration required");
                isValid = false;
            }
            else setValid("Duration");


            if (!price) {
                setError("Price", "Price required");
                isValid = false;
            }
            else setValid("Price");


            if (!start) {
                setError("StartDate", "Start date required");
                isValid = false;
            }
            else setValid("StartDate");


            if (!end) {
                setError("EndDate", "End date required");
                isValid = false;
            }
            else if (start && end < start) {
                setError("EndDate", "End date must be greater than start date");
                isValid = false;
            }
            else setValid("EndDate");


            if (!isValid) {
                return;
            }

            var btn = document.activeElement;
            btn.disabled = true;

            var formData = new FormData();

            formData.append("FarmHouseCode", $("#FarmHouseCode").val());
            formData.append("ActivityName", $("#ActivityName").val());
            formData.append("Duration", $("#Duration").val());
            formData.append("Price", $("#Price").val());
            formData.append("Description", $("#Description").val());
            formData.append("StartDate", $("#StartDate").val());
            formData.append("EndDate", $("#EndDate").val());

            var file = $("#ActivityImage")[0].files[0];

            if (file) {

                const allowedExtensions = ['jpg', 'jpeg', 'png'];
                const maxSize = 2 * 1024 * 1024; // 2MB

                let extension = file.name.split('.').pop().toLowerCase();

                if (!allowedExtensions.includes(extension)) {

                    ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG images allowed");
                    btn.disabled = false;
                    return;
                }

                if (file.size > maxSize) {

                    ShowAlert("warning", "Validation", "Image size must be less than 2MB");
                    btn.disabled = false;
                    return;
                }

                formData.append("ImageFile", file);
            }

            $.ajax({
                url: '/FarmOwner/InsertActivityAG',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function () {

                    ShowAlert(
                        "success",
                        "Saved!",
                        "Activity added successfully",
                        true
                    );
                },
                complete: function () {
                    btn.disabled = false;
                }
            });
        }

    </script>

    <script>
        // Loads activity data from server and populates Edit modal
        function EditActivity(id) {

            console.log("Edit clicked:", id);

            $.get('/FarmOwner/GetActivityByIdAG', { id: id }, function (data) {

                console.log(data);

                $("#EditActivityId").val(data.ActivityId);
                $("#EditFarmHouseCode").val(data.FarmHouseCode);
                $("#EditActivityCode").val(data.ActivityCode);

                $("#EditActivityName").val(data.ActivityName);
                $("#EditDuration").val(data.Duration);
                $("#EditPrice").val(data.Price);
                $("#EditDescription").val(data.Description);

                if (data.StartDate) {
                    var sd = new Date(data.StartDate);

                    if (!isNaN(sd.getTime())) {
                        $("#EditStartDate").val(sd.toISOString().split('T')[0]);
                    }
                }

                if (data.EndDate) {
                    var ed = new Date(data.EndDate);

                    if (!isNaN(ed.getTime())) {
                        $("#EditEndDate").val(ed.toISOString().split('T')[0]);
                    }
                }

                if (data.ImagePath) {
                    $("#EditPreviewImage").attr("src", data.ImagePath).show();
                }

                var editModal = new bootstrap.Modal(document.getElementById('editActivityModal'));
                editModal.show();

            });
        }
    </script>
    <script>

        // Updates activity details using AJAX request
        function UpdateActivity() {



            let isValid = true;

            let farm = $("#EditFarmHouseCode").val();
            let name = $("#EditActivityName").val().trim();
            let duration = $("#EditDuration").val().trim();
            let price = $("#EditPrice").val();
            let start = $("#EditStartDate").val();
            let end = $("#EditEndDate").val();

            if (!farm) {
                setError("EditFarmHouseCode", "Please select farmhouse");
                isValid = false;
            } else setValid("EditFarmHouseCode");

            if (!name) {
                setError("EditActivityName", "Activity name required");
                isValid = false;
            } else setValid("EditActivityName");

            if (!duration) {
                setError("EditDuration", "Duration required");
                isValid = false;
            } else setValid("EditDuration");

            if (!price) {
                setError("EditPrice", "Price required");
                isValid = false;
            } else setValid("EditPrice");

            if (!start) {
                setError("EditStartDate", "Start date required");
                isValid = false;
            } else setValid("EditStartDate");

            if (!end) {
                setError("EditEndDate", "End date required");
                isValid = false;
            }
            else if (start && end < start) {
                setError("EditEndDate", "End date must be greater than start date");
                isValid = false;
            }
            else setValid("EditEndDate");

            if (!isValid) {
                return;
            }

            var formData = new FormData();

            formData.append("ActivityId", $("#EditActivityId").val());
            formData.append("FarmHouseCode", $("#EditFarmHouseCode").val());
            formData.append("ActivityCode", $("#EditActivityCode").val());
            formData.append("ActivityName", $("#EditActivityName").val());
            formData.append("Duration", $("#EditDuration").val());
            formData.append("Price", $("#EditPrice").val());
            formData.append("Description", $("#EditDescription").val());
            var startDate = $("#EditStartDate").val();
            var endDate = $("#EditEndDate").val();
            var file = $("#EditImage")[0].files[0];

            if (file) {

                const allowedExtensions = ['jpg', 'jpeg', 'png'];
                const maxSize = 2 * 1024 * 1024;

                let extension = file.name.split('.').pop().toLowerCase();

                if (!allowedExtensions.includes(extension)) {

                    ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG images allowed");
                    return;
                }

                if (file.size > maxSize) {

                    ShowAlert("warning", "Validation", "Image must be less than 2MB");
                    return;
                }

                formData.append("ImageFile", file);
            }

            $.ajax({
                url: '/FarmOwner/UpdateActivityAG',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function () {

                    ShowAlert(
                        "success",
                        "Updated!",
                        "Activity updated successfully",
                        true
                    );
                }
            });
        }

    </script>
    <script>

        // Deletes selected activity after confirmation dialog
        function DeleteActivity(id) {

            Swal.fire({
                title: "Delete Activity?",
                text: "This action cannot be undone",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                confirmButtonText: "Yes, delete it"
            }).then((result) => {

                if (result.isConfirmed) {

                    // Loader
                    Swal.fire({
                        title: 'Deleting...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading()
                        }
                    });

                    $.post('/FarmOwner/DeleteActivityAG',
                        { id: id },
                        function () {

                            ShowAlert(
                                "success",
                                "Deleted!",
                                "Activity deleted successfully",
                                true
                            );

                        });

                }
            });
        }
    </script>
    <script>

        // Activates or deactivates activity
        function ToggleStatus(id, status) {

            $.post('/FarmOwner/ToggleActivityAG',
                {
                    id: id,
                    isActive: status
                })
                .done(function () {

                    let message = status
                        ? "Activity ACTIVATED successfully"
                        : "Activity DEACTIVATED successfully";

                    ShowAlert("success", "Success", message, false);

                })
                .fail(function () {

                    ShowAlert("error", "Error", "Failed to update status", false);

                });
        }
    </script>

    <script>
        // Initialize DataTable for activity listing
        $(document).ready(function () {

            $('#dataTable').DataTable({
                responsive: true,
                pageLength: 10,
                ordering: false,
                lengthChange: true,
                pagingType: "simple_numbers"
            });

        });

    </script>

    <script>

        $("#FarmHouseCode,#ActivityName,#Duration,#Price,#StartDate,#EndDate")
            .on("input change", function () {

                let id = $(this).attr("id");
                let value = $(this).val();

                if (value && value.trim() !== "") {
                    setValid(id);
                }

            });

    </script>

    <script>

        $("#EditFarmHouseCode,#EditActivityName,#EditDuration,#EditPrice,#EditStartDate,#EditEndDate")
            .on("input change", function () {

                let id = $(this).attr("id");
                let value = $(this).val();

                if (value && value.trim() !== "") {
                    setValid(id);
                }

            });

    </script>

    <script>

        $("#StartDate").on("change", function () {

            $("#EndDate").trigger("change");

        });

    </script>

    <script>

        $("#EditStartDate").on("change", function () {

            $("#EditEndDate").trigger("change");

        });

    </script>

    <script>
        $("#ActivityImage").on("change", function () {

            let file = this.files[0];

            if (!file) return;

            const allowedExtensions = ['jpg', 'jpeg', 'png'];
            const maxSize = 2 * 1024 * 1024;

            let extension = file.name.split('.').pop().toLowerCase();

            if (!allowedExtensions.includes(extension)) {

                ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG allowed");
                this.value = "";
                return;
            }

            if (file.size > maxSize) {

                ShowAlert("warning", "Validation", "Image must be below 2MB");
                this.value = "";
                return;
            }

            let reader = new FileReader();

            reader.onload = function (e) {

                $("#PreviewImage")
                    .attr("src", e.target.result)
                    .show();
            }

            reader.readAsDataURL(file);

        });
    </script>
}