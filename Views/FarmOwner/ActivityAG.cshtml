        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {

            // 🔹 Farmhouse Filter
            var selectedFarm = $("#FilterFarmHouse").val();
            var rowFarmName = data[2]; // Farmhouse column text
            var selectedFarm = $("#FilterFarmHouse option:selected").text();

            if (selectedFarm && selectedFarm !== "All Farmhouses" && rowFarmName.trim() !== selectedFarm.trim()) {
                return false;
            }

            // 🔹 Date Filter
            var startFilter = $('#filterStartDate').val();
            var endFilter = $('#filterEndDate').val();

            var startDate = data[6];
            var endDate = data[7];

            if (!startFilter && !endFilter) {
                return true;
            }

            var activityStart = startDate ? new Date(startDate + "T00:00:00") : null;
            var activityEnd = endDate ? new Date(endDate + "T00:00:00") : null;

            var filterStart = startFilter ? new Date(startFilter + "T00:00:00") : null;
            var filterEnd = endFilter ? new Date(endFilter + "T00:00:00") : null;

            if (filterStart && activityStart < filterStart) return false;
            if (filterEnd && activityEnd > filterEnd) return false;

            return true;
        });

