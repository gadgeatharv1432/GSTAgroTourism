        function hasSelectedRows() {

            return $(".rowCheckbox:checked").length > 0;

        }

// Apply date filter when date changes
        $("#filterStartDate, #filterEndDate").on("change", function () {

            table.draw();

        });
// Reset all filters
        $("#clearDateFilter").click(function () {
            $("#FilterFarmHouse").val("");
            $("#filterStartDate").val("");
            $("#filterEndDate").val("");
            $(".rowCheckbox").prop("checked", false);
            $("#selectAll").prop("checked", false);
            table.search('').columns().search('').draw();
        });

// Select All Checkbox
        $("#selectAll").on("change", function () {

            $(".rowCheckbox").prop("checked", this.checked);

        });
// Uncheck selectAll if one row unchecked
        $(document).on("change", ".rowCheckbox", function () {

            if (!this.checked) {
                $("#selectAll").prop("checked", false);
            }

        });

        $("#FarmHouseCode,#ActivityName,#Duration,#Price,#StartDate,#EndDate")
            .on("input change", function () {

                let id = $(this).attr("id");
                let value = $(this).val();
                if (value && value.trim() !== "") {
                    setValid(id);
                }
            });

        $("#EditFarmHouseCode,#EditActivityName,#EditDuration,#EditPrice,#EditStartDate,#EditEndDate")
            .on("input change", function () {
                let id = $(this).attr("id");
                let value = $(this).val();

                if (value && value.trim() !== "") {
                    setValid(id);
                }
            });

        $("#StartDate").on("change", function () {
            let startDate = $(this).val();
            if (!startDate) {
                $("#EndDate").prop("disabled", true).val("");
                return;
            }
            $("#EndDate").prop("disabled", false);
            $('#EndDate').datepicker('setStartDate', toDate(startDate));
            let endDate = $("#EndDate").val();
            if (endDate && toDate(endDate) < toDate(startDate)) {
                $("#EndDate").val("");
            }
        });

        $("#EndDate").on("change", function () {
            let start = $("#StartDate").val();
            let end = $(this).val();
            let startDate = start ? toDate(start) : null;
            let endDate = end ? toDate(end) : null;
            if (startDate && endDate && endDate < startDate) {
                ShowAlert("warning", "Validation", "End date cannot be before Start date");
                $(this).val("");
            }
        });

        $("#EditStartDate").on("change", function () {
            let startDate = $(this).val();
            if (!startDate) {
                $("#EditEndDate").prop("disabled", true);
                $("#EditEndDate").val("");
                return;
            }
            $("#EditEndDate").prop("disabled", false);
            $('#EditEndDate').datepicker('setStartDate', toDate(startDate));
            let endVal = $("#EditEndDate").val();
            let startObj = toDate(startDate);
            let endObj = endVal ? toDate(endVal) : null;
            if (endObj && endObj < startObj) {
                $("#EditEndDate").val("");
            }
        });
// Validate image file type and size
        $("#ActivityImage").on("change", function () {
            let file = this.files[0];
            if (!file) return;
            const allowedExtensions = ['jpg', 'jpeg', 'png'];
            const maxSize = 2 * 1024 * 1024;
            let extension = file.name.split('.').pop().toLowerCase();
            if (!allowedExtensions.includes(extension)) {
                ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG allowed");
                this.value = "";
                return;
            }
            if (file.size > maxSize) {
                ShowAlert("warning", "Validation", "Image must be below 2MB");
                this.value = "";
                return;
            }
            let reader = new FileReader();
            reader.onload = function (e) {
                $("#PreviewImage")
                    .attr("src", e.target.result)
                    .show();
            }
            reader.readAsDataURL(file);
        });
    </script>
