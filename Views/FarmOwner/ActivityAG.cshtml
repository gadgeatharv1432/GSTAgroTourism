@model  List<AgroClassLib.FarmOwner.FarmActivitiesAG>

@{
    ViewBag.Title = "ActivityAG";
    Layout = "~/Views/Shared/FarmOwner.cshtml";
}
<style>
    /*    #editActivityModal .modal-content {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }*/

    .form-error {
        color: #dc3545;
        font-size: 13px;
        margin-top: 4px;
    }

    .input-error {
        border: 2px solid #dc3545 !important;
    }

    .input-valid {
        border: 2px solid #28a745 !important;
    }

    .dt-buttons {
        display: none;
    }

    .btn-rounded {
        border-radius: 8px;
        padding: 6px 18px;
        font-weight: 500;
    }

    #filters {
        border: 1px solid #28a745;
        border-radius: 10px;
        background: white;
        padding: 12px 15px;
        margin-bottom: 10px;
    }

    .dataTables_length select {
        background-image: none !important;
    }
    
    #dataTable td,
    #dataTable th {
        padding: 6px 8px !important;
        font-size: 13px;
        vertical-align: middle;
    }

    .btn-sm {
        padding: 3px 8px !important;
        font-size: 12px;
    }

    #dataTable thead th {
        font-size: 15px;
        padding: 4px;
    }
    /* Export Buttons */

    .export-btn {
        width: 45px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    /* PDF */

    .pdf-btn {
        border-color: #dc3545;
        color: #dc3545;
    }

        .pdf-btn:hover {
            background: #dc3545;
            color: #fff;
        }

    /* Excel */

    .excel-btn {
        border-color: #28a745;
        color: #28a745;
    }

        .excel-btn:hover {
            background: #28a745;
            color: #fff;
        }

    /* Print */

    .print-btn {
        border-color: #6c757d;
        color: #6c757d;
    }

        .print-btn:hover {
            background: #6c757d;
            color: #fff;
        }

    /* Responsive Toggle Switch */

    .switch {
        position: relative;
        display: inline-block;
        width: 2.8em; /* scalable */
        height: 1.4em;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background: linear-gradient(135deg, #ccc, #bbb);
        transition: 0.4s;
        border-radius: 2em;
    }

        /* Circle */
        .slider:before {
            content: "";
            position: absolute;
            height: 1em;
            width: 1em;
            left: 0.2em;
            bottom: 0.2em;
            background-color: white;
            transition: 0.4s;
            border-radius: 50%;
        }

    /* ON STATE */
    .switch input:checked + .slider {
        background: linear-gradient(135deg, #00cfff, #003847);
    }

        /* MOVE CIRCLE */
        .switch input:checked + .slider:before {
            transform: translateX(1.4em);
        }
    /* CALENDAR */
    .datepicker-dropdown {
        z-index: 9999 !important;
    }

    .date-input {
        padding-right: 35px;
    }

    .calendar-icon {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #000;
    }
    .datepicker {
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

        .datepicker table tr td.active,
        .datepicker table tr td.active:hover {
            background-color: #0d6efd !important;
            color: #fff !important;
            border-radius: 6px;
        }

        .datepicker table tr td.today {
            background-color: #e9f5ff !important;
            border-radius: 6px;
        }
</style>

<!-- Button to open Add Activity modal -->
<button class="btn btn-success" onclick="OpenAddModal()">
    + Add Activity
</button>

<div class="container-fluid" id="filters">

    <div class="d-flex align-items-center gap-lg-2 mb-3 flex-wrap" id="exportToolbar">

        <!-- Farmhouse Filter -->
        <div>
            <label class="fw-semibold me-1">Farmhouse:</label>

            @Html.DropDownList(
                "FilterFarmHouse",
                (List<SelectListItem>)ViewBag.FarmHouseList,
                "All Farmhouses",
                new { @class = "form-control form-control-sm", id = "FilterFarmHouse", style = "width:150px; display:inline-block;" }
            )
        </div>

        <!-- Date Range Filter -->

        <div>
            <label class="fw-semibold me-1">From:</label>

            <div class="position-relative" style="display:inline-block; width:130px;">
                <input type="text"
                       id="filterStartDate"
                       class="form-control form-control-sm date-input"
                       placeholder="dd-mm-yyyy">
                <i class="fa fa-calendar calendar-icon"></i>
            </div>
        </div>

        <div>
            <label class="fw-semibold me-1">To:</label>

            <div class="position-relative" style="display:inline-block; width:130px;">
                <input type="text"
                       id="filterEndDate"
                       class="form-control form-control-sm date-input"
                       placeholder="dd-mm-yyyy">
                <i class="fa fa-calendar calendar-icon"></i>
            </div>
        </div>

        <button class="btn btn-outline-danger btn-sm"
                id="clearDateFilter">
            Reset Filters
        </button>

        <!-- Export Buttons -->
        <button id="btnPdf" class="export-btn pdf-btn" data-bs-toggle="tooltip" title="Export PDF">
            <i class="fas fa-file-pdf"></i>
        </button>

        <button id="btnExcel" class="export-btn excel-btn" data-bs-toggle="tooltip" title="Export Excel">
            <i class="fas fa-file-excel"></i>
        </button>

        <button id="btnPrint" class="export-btn print-btn" data-bs-toggle="tooltip" title="Print">
            <i class="fas fa-print"></i>
        </button>

    </div>
</div>

<!-- Activity Data Table -->
<table id="dataTable"
       class="table table-md table-hover table-striped"
       style="width:100%">

    <thead>
        <tr>
            <th style="width:40px">
                <input type="checkbox" id="selectAll">
            </th>
            <th style="width:60px">Sr No.</th>
            <th style="width:120px">Farmhouse</th>
            <th style="width:120px">Name</th>
            <th style="width:90px">Duration</th>
            <th style="width:80px">Price</th>
            <th style="width:100px">Start Date</th>
            <th style="width:100px">End Date</th>
            <th style="width:150px">Description</th>
            <th style="width:80px">Image</th>
            <th style="width:70px">Status</th>
            <th style="width:130px;">Action</th>
        </tr>
    </thead>

    <tbody>
        @{ int sr = 1; }

        @foreach (var item in Model)
        {
            <tr data-farmhouse="@item.FarmHouseCode">
                <td>
                    <input type="checkbox"
                           class="rowCheckbox"
                           value="@item.ActivityId">
                </td>

                <td>@sr</td>

                <td>@item.FarmHouseName</td>

                <td>@item.ActivityName</td>

                <td>@item.Duration</td>

                <td>@item.Price</td>

                <td>@(item.StartDate?.ToString("yyyy-MM-dd"))</td>

                <td>@(item.EndDate?.ToString("yyyy-MM-dd"))</td>

                <td>@item.Description</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" style="width:60px;height:40px;object-fit:cover;border-radius:4px;">
                    }
                </td>

                <td>
                    <label class="switch">
                        <input type="checkbox"
                               onchange="ToggleStatus(@item.ActivityId,this.checked)"
                               @(item.IsActive ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </td>

                <td>
                    <div style="display:flex;gap:4px;justify-content:center;white-space:nowrap;">

                        <button type="button"
                                class="btn btn-outline-primary btn-rounded btn-sm"
                                onclick="EditActivity(@item.ActivityId)">

                            <i class="fa fa-pencil me-1"></i> Edit
                        </button>

                        <button type="button"
                                class="btn btn-outline-danger btn-rounded btn-sm"
                                onclick="DeleteActivity(@item.ActivityId)">

                            <i class="fa fa-trash me-1"></i> Delete
                        </button>

                    </div>
                </td>

            </tr>
            sr++;
        }

    </tbody>

</table>

<!-- Add Activity Modal -->
<div id="addActivityModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-fullscreen-lg-down">
        <div class="modal-content">

            <div class="modal-header text-bg-success text-white">
                <h5 class="modal-title">Add Activity</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="container-fluid">

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Farmhouse</label>
                        <div class="col-sm-8">

                            @Html.DropDownList(
                             "FarmHouseCode",
                             (List<SelectListItem>)ViewBag.FarmHouseList,
                             "-- Select Farmhouse --",
                             new { @class = "form-control", id = "FarmHouseCode" }
                         )

                            <div id="FarmHouseCodeError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Start Date</label>
                        <div class="col-sm-8 position-relative">

                            <input type="text"
                                   id="StartDate"
                                   class="form-control date-input"
                                   placeholder="dd-mm-yyyy">

                            <i class="fa fa-calendar calendar-icon"></i>

                            <div id="StartDateError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">End Date</label>
                        <div class="col-sm-8 position-relative">

                            <input type="text"
                                   id="EndDate"
                                   class="form-control date-input"
                                   placeholder="dd-mm-yyyy">

                            <i class="fa fa-calendar calendar-icon"></i>

                            <div id="EndDateError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Name</label>
                        <div class="col-sm-8">

                            <input type="text"
                                   id="ActivityName"
                                   class="form-control"
                                   placeholder="Enter activity name"
                                   pattern="^[A-Za-z\s]+$"
                                   oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'')">

                            <div id="ActivityNameError" class="form-error"></div>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Duration</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="Duration"
                                   class="form-control"
                                   placeholder="Example: 2 Hours"
                                   pattern="^[0-9A-Za-z\s]+$"
                                   title="Only numbers and letters allowed">
                            <div id="DurationError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Price</label>
                        <div class="col-sm-8">
                            <input type="number"
                                   id="Price"
                                   class="form-control"
                                   placeholder="Enter price"
                                   min="1"
                                   step="0.01">
                            <div id="PriceError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Description</label>
                        <div class="col-sm-8">
                            <textarea id="Description"
                                      rows="3"
                                      maxlength="250"
                                      class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Image</label>
                        <div class="col-sm-8">
                            <input type="file" id="ActivityImage" class="form-control" accept=".jpg,.jpeg,.png">
                            <img id="PreviewImage" style="width:90px;height:60px;display:none;border-radius:5px;margin-top:10px;">
                        </div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-outline-success btn-rounded"
                        onclick="SaveActivity()">

                    <i class="fa fa-check me-1"></i> Save
                </button>

                <button type="button"
                        class="btn btn-outline-danger btn-rounded"
                        data-bs-dismiss="modal">

                    <i class="fa fa-times me-1"></i> Cancel
                </button>

            </div>

        </div>
    </div>
</div>


<!-- Edit Activity Modal -->
<div id="editActivityModal" class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-fullscreen-lg-down">
        <div class="modal-content">

            <div class="modal-header text-bg-warning text-black">
                <h5 class="modal-title">Edit Activity</h5>
                <button type="button" class="btn-close btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="container-fluid">

                    <input type="hidden" id="EditActivityId">
                    <input type="hidden" id="EditActivityCode">

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Farmhouse</label>
                        <div class="col-sm-8">

                            @Html.DropDownList(
                                "EditFarmHouseCode",
                                (List<SelectListItem>)ViewBag.FarmHouseList,
                                "-- Select Farmhouse --",
                                new { @class = "form-control", id = "EditFarmHouseCode" }
                            )
                            <div id="EditFarmHouseCodeError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Start Date</label>
                        <div class="col-sm-8 position-relative">

                            <input type="text"
                                   id="EditStartDate"
                                   class="form-control date-input"
                                   placeholder="dd-mm-yyyy">

                            <i class="fa fa-calendar calendar-icon"></i>

                            <div id="EditStartDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">End Date</label>
                        <div class="col-sm-8 position-relative">

                            <input type="text"
                                   id="EditEndDate"
                                   class="form-control date-input"
                                   placeholder="dd-mm-yyyy">

                            <i class="fa fa-calendar calendar-icon"></i>

                            <div id="EditEndDateError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Activity Name</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="EditActivityName"
                                   class="form-control"
                                   pattern="^[A-Za-z\s]+$"
                                   oninput="this.value=this.value.replace(/[^A-Za-z\s]/g,'')">
                            <div id="EditActivityNameError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Duration</label>
                        <div class="col-sm-8">
                            <input type="text"
                                   id="EditDuration"
                                   class="form-control"
                                   pattern="^[0-9A-Za-z\s]+$">
                            <div id="EditDurationError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Price</label>
                        <div class="col-sm-8">
                            <input type="number"
                                   id="EditPrice"
                                   class="form-control"
                                   min="1"
                                   step="0.01">
                            <div id="EditPriceError" class="form-error"></div>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Description</label>
                        <div class="col-sm-8">
                            <textarea id="EditDescription"
                                      rows="3"
                                      maxlength="250"
                                      class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <label class="col-sm-4 col-form-label fw-semibold">Image</label>
                        <div class="col-sm-8">
                            <input class="form-control" type="file" id="EditImage" accept=".jpg,.jpeg,.png">
                            <br />
                            <img id="EditPreviewImage" style="width:90px;height:60px;display:none;border-radius:5px;object-fit:cover;" />
                        </div>
                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-outline-success btn-rounded"
                        onclick="UpdateActivity()">

                    <i class="fa fa-check me-1"></i> Update
                </button>

                <button type="button"
                        class="btn btn-outline-danger btn-rounded"
                        data-bs-dismiss="modal">

                    <i class="fa fa-times me-1"></i> Cancel
                </button>

            </div>

        </div>
    </div>
</div>

@section scripts{
    <script>
// Utility function for displaying SweetAlert notifications
        function ShowAlert(type, title, message, reload = false) {

            Swal.fire({
                icon: type,
                title: title,
                text: message,
                confirmButtonColor: "#27ae60"
            }).then(() => {

                if (reload)
                    location.reload();
            });
        }

// Convert UI (dd-mm-yyyy) into (yyyy-MM-dd)
        function convertToISO(dateStr) {
            if (!dateStr) return null;

            let parts = dateStr.split("-");
            return parts[2] + "-" + parts[1] + "-" + parts[0];
        }
// Convert date strings into JavaScript Date objects
        function toDate(dateStr) {
            if (!dateStr) return null;
            let parts = dateStr.split("-");
            if (parts[0].length === 4) {
                return new Date(parts[0], parts[1] - 1, parts[2]);
            }
            return new Date(parts[2], parts[1] - 1, parts[0]);
        }
// Generate current date comparisons
        function today() {
            let t = new Date();
            t.setHours(0, 0, 0, 0);
            return t;
        }

// Opens Add Activity modal and resets all form fields
        function OpenAddModal() {

            $("#StartDate").val("");
            $("#EndDate").val("");
            $('#StartDate').datepicker('setStartDate', today());
            $("#EndDate").prop("disabled", true).val("");
            $("#EndDate").prop("disabled", true);
            $("#FarmHouseCode").val("");
            $("#ActivityName").val("");
            $("#Duration").val("");
            $("#Price").val("");
            $("#Description").val("");
            $("#ActivityImage").val("");
            $("#PreviewImage").hide();
            $(".form-control").removeClass("input-error input-valid");
            $(".form-error").text("");
            const modal = new bootstrap.Modal(document.getElementById('addActivityModal'));
            modal.show();
        }

        $(document).ready(function () {
// FILTER date
            $('#filterStartDate, #filterEndDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                todayHighlight: true
            });
// ADD date
            $('#StartDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                todayHighlight: true,
                startDate: today()
            });
            $('#EndDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                todayHighlight: true
            });
// EDIT date
            $('#EditStartDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                todayHighlight: true,
                startDate: today()
            });
            $('#EditEndDate').datepicker({
                format: 'dd-mm-yyyy',
                autoclose: true,
                todayHighlight: true
            });
        });
        function setError(inputId, message) {
            $("#" + inputId).removeClass("input-valid").addClass("input-error");
            $("#" + inputId + "Error").text(message);
        }
        function setValid(inputId) {
            $("#" + inputId).removeClass("input-error").addClass("input-valid");
            $("#" + inputId + "Error").text("");
        }
//Validate activity form inputs, prepare form data, and submit 
        function SaveActivity() {
            let isValid = true;
            let farm = $("#FarmHouseCode").val();
            let name = $("#ActivityName").val().trim();
            let duration = $("#Duration").val().trim();
            let price = $("#Price").val();
            let start = $("#StartDate").val();
            let end = $("#EndDate").val();
            let startDateObj = start ? toDate(start) : null;
            let endDateObj = end ? toDate(end) : null;
// BASIC VALIDATION
            if (!farm) {
                setError("FarmHouseCode", "Please select farmhouse");
                isValid = false;
            } else setValid("FarmHouseCode");

            if (!name) {
                setError("ActivityName", "Activity name required");
                isValid = false;
            } else setValid("ActivityName");

            if (!duration) {
                setError("Duration", "Duration required");
                isValid = false;
            } else setValid("Duration");

            if (!price) {
                setError("Price", "Price required");
                isValid = false;
            } else setValid("Price");
// DATE VALIDATION 
            if (!start) {
                setError("StartDate", "Start date required");
                isValid = false;
            }
            else if (startDateObj < today()) {
                setError("StartDate", "Start date cannot be in the past");
                isValid = false;
            }
            else setValid("StartDate");

            if (!end) {
                setError("EndDate", "End date required");
                isValid = false;
            }
            else if (endDateObj < startDateObj) {
                setError("EndDate", "End date must be greater than start date");
                isValid = false;
            }
            else setValid("EndDate");

            if (!isValid) return;
            var btn = $("#addActivityModal .btn-outline-success")[0];
            btn.disabled = true;
            var formData = new FormData();
            formData.append("FarmHouseCode", farm);
            formData.append("ActivityName", name);
            formData.append("Duration", duration);
            formData.append("Price", price);
            formData.append("Description", $("#Description").val());
            formData.append("StartDate", convertToISO(start));
            formData.append("EndDate", convertToISO(end));
// ===== IMAGE VALIDATION =====
            var file = $("#ActivityImage")[0].files[0];
            if (file) {
                const allowedExtensions = ['jpg', 'jpeg', 'png'];
                const maxSize = 2 * 1024 * 1024;
                let extension = file.name.split('.').pop().toLowerCase();
                if (!allowedExtensions.includes(extension)) {
                    ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG images allowed");
                    btn.disabled = false;
                    return;
                }
                if (file.size > maxSize) {
                    ShowAlert("warning", "Validation", "Image size must be less than 2MB");
                    btn.disabled = false;
                    return;
                }
                formData.append("ImageFile", file);
            }
            $.ajax({
                url: '/FarmOwner/InsertActivityAG',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {

                    if (res.success) {
                        ShowAlert("success", "Saved!", "Activity added successfully", true);
                    } else {
                        ShowAlert("error", "Validation Error", res.message);
                    }

                },
                error: function () {
                    ShowAlert("error", "Error", "Server error occurred");
                },
                complete: function () {
                    btn.disabled = false;
                }
            });
        }
// Fetch selected activity data, populate edit form fields, and open edit modal
        function EditActivity(id) {
            console.log("Edit clicked:", id);
            $.get('/FarmOwner/GetActivityByIdAG', { id: id }, function (data) {

                console.log(data);
                $("#EditActivityId").val(data.ActivityId);
                $("#EditFarmHouseCode").val(data.FarmHouseCode);
                $("#EditActivityCode").val(data.ActivityCode);
                $("#EditActivityName").val(data.ActivityName);
                $("#EditDuration").val(data.Duration);
                $("#EditPrice").val(data.Price);
                $("#EditDescription").val(data.Description);
 // ===== START DATE =====
                if (data.StartDate) {
                    let sd = new Date(data.StartDate);

                    let localStart =
                        String(sd.getDate()).padStart(2, '0') + '-' +
                        String(sd.getMonth() + 1).padStart(2, '0') + '-' +
                        sd.getFullYear();

                    $("#EditStartDate").val(localStart);
                }
// ===== END DATE =====
                if (data.EndDate) {
                    let ed = new Date(data.EndDate);
                    let localEnd =
                        String(ed.getDate()).padStart(2, '0') + '-' +
                        String(ed.getMonth() + 1).padStart(2, '0') + '-' +
                        ed.getFullYear();
                    $("#EditEndDate").val(localEnd);
                }
                $('#EditStartDate').datepicker('setStartDate', today());
                let startDate = $("#EditStartDate").val();
                if (startDate) {
                    $("#EditEndDate").prop("disabled", false);
                    $('#EditEndDate').datepicker('setStartDate', toDate(startDate));
                } else {
                    $("#EditEndDate").prop("disabled", true);
                    $("#EditEndDate").val("");
                }
// ===== IMAGE =====
                if (data.ImagePath) {
                    $("#EditPreviewImage").attr("src", data.ImagePath).show();
                }
// ===== OPEN MODAL =====
                var editModal = new bootstrap.Modal(document.getElementById('editActivityModal'));
                editModal.show();
            });
        }
// Validate edit form inputs, prepare updated activity data, and submit
         function UpdateActivity() {
            let isValid = true;
            let farm = $("#EditFarmHouseCode").val();
            let name = $("#EditActivityName").val().trim();
            let duration = $("#EditDuration").val().trim();
            let price = $("#EditPrice").val();
            let start = $("#EditStartDate").val();
            let end = $("#EditEndDate").val();
            let startDateObj = start ? toDate(start) : null;
            let endDateObj = end ? toDate(end) : null;
 // ===== BASIC VALIDATION =====
            if (!farm) {
                setError("EditFarmHouseCode", "Please select farmhouse");
                isValid = false;
            } else setValid("EditFarmHouseCode");

            if (!name) {
                setError("EditActivityName", "Activity name required");
                isValid = false;
            } else setValid("EditActivityName");

            if (!duration) {
                setError("EditDuration", "Duration required");
                isValid = false;
            } else setValid("EditDuration");

            if (!price) {
                setError("EditPrice", "Price required");
                isValid = false;
            } else setValid("EditPrice");
// ===== DATE VALIDATION (CORRECTED) =====
            if (!start) {
                setError("EditStartDate", "Start date required");
                isValid = false;
            }
            else if (startDateObj < today()) {
                setError("EditStartDate", "Start date cannot be in the past");
                isValid = false;
            }
            else setValid("EditStartDate");

            if (!end) {
                setError("EditEndDate", "End date required");
                isValid = false;
            }
            else if (endDateObj < startDateObj) {
                setError("EditEndDate", "End date must be greater than start date");
                isValid = false;
            }
            else setValid("EditEndDate");

            if (!isValid) return;
// ===== FORM DATA =====
            var formData = new FormData();
            formData.append("ActivityId", $("#EditActivityId").val());
            formData.append("FarmHouseCode", farm);
            formData.append("ActivityCode", $("#EditActivityCode").val());
            formData.append("ActivityName", name);
            formData.append("Duration", duration);
            formData.append("Price", price);
            formData.append("Description", $("#EditDescription").val());
            formData.append("StartDate", convertToISO(start));
             formData.append("EndDate", convertToISO(end));
// ===== IMAGE VALIDATION =====
            var file = $("#EditImage")[0].files[0];
            if (file) {
                const allowedExtensions = ['jpg', 'jpeg', 'png'];
                const maxSize = 2 * 1024 * 1024;
                let extension = file.name.split('.').pop().toLowerCase();
                if (!allowedExtensions.includes(extension)) {
                    ShowAlert("warning", "Validation", "Only JPG, JPEG and PNG images allowed");
                    return;
                }
                if (file.size > maxSize) {
                    ShowAlert("warning", "Validation", "Image must be less than 2MB");
                    return;
                }
                formData.append("ImageFile", file);
            }
            $.ajax({
                url: '/FarmOwner/UpdateActivityAG',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (res)
                {
                    if (res.success) {
                        ShowAlert("success", "Updated!", "Activity updated successfully", true);
                    } else {
                        ShowAlert("error", "Validation Error", res.message);
                    }
                }
            });
        }
// Trigger user confirmation and execute activity deletion 
        function DeleteActivity(id) {
            Swal.fire({
                title: "Delete Activity?",
                text: "This action cannot be undone",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                confirmButtonText: "Yes, delete it"
            })
            .then((result) =>
            {
            if (result.isConfirmed) {
// Loader
                Swal.fire({
                    title: 'Deleting...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading()
                    }
                });
                $.post('/FarmOwner/DeleteActivityAG',
                    { id: id },
                    function () {
                        ShowAlert(
                            "success",
                            "Deleted!",
                            "Activity deleted successfully",
                            true
                        );
                    });
                }
            });
        }
// Activates or deactivates activity
        function ToggleStatus(id, status) {
            $.post('/FarmOwner/ToggleActivityAG',
                {
                    id: id,
                    isActive: status
                })
            .done(function () {
                let message = status
                    ? "Activity ACTIVATED successfully"
                    : "Activity DEACTIVATED successfully";
                ShowAlert("success", "Success", message, false);
            })
            .fail(function () {
                ShowAlert("error", "Error", "Failed to update status", false);
            });
        }
// Date Range Filtering
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
            var selectedFarmText = $("#FilterFarmHouse option:selected").text();
            var rowFarmName = data[2];
            if (selectedFarmText && selectedFarmText !== "All Farmhouses" &&
                rowFarmName.trim() !== selectedFarmText.trim()) {
                return false;
            }
            var startFilter = $('#filterStartDate').val();
            var endFilter = $('#filterEndDate').val();
            var startDate = data[6];
            var endDate = data[7];
            var activityStart = startDate ? toDate(startDate) : null;
            var activityEnd = endDate ? toDate(endDate) : null;
            var filterStart = startFilter ? toDate(startFilter) : null;
            var filterEnd = endFilter ? toDate(endFilter) : null;
            if (filterStart && filterEnd && filterEnd < filterStart) {
                return false;
            }
            if (filterStart && activityStart && activityStart < filterStart) {
                return false;
            }
            if (filterEnd && activityStart && activityStart > filterEnd) {
                return false;
            }
            return true;
        });
        function getExportDateTime() {

            const now = new Date();

            return now.toLocaleDateString() + " " + now.toLocaleTimeString();

        }
        $("#FilterFarmHouse").on("change", function () {
            table.draw();
        });
// Initialize DataTable with pagination, export options
        var table;
        var exportRowIndex = 0;
        $(document).ready(function () {
            table = $('#dataTable').DataTable({
                responsive: true,
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                ordering: false,
                lengthChange: true,
                pagingType: "simple_numbers",
                columnDefs: [{
                    orderable: false,
                    targets: 0
                }],
                dom: '<"row mb-2"<"col-md-6 d-flex align-items-center"l><"col-md-6 text-end"f>>rtipB',
                buttons: [
// PDF 
                    {
                        extend: 'pdfHtml5',
