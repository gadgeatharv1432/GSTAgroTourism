                ]
            });

        });
// Trigger PDF export only if at least one row is selected
        $("#btnPdf").click(function () {

            if (!hasSelectedRows()) {

                Swal.fire("Select rows", "Please select at least one activity", "warning");
                return;
            }

            table.button('.buttons-pdf').trigger();

        });
// Trigger Excel export only if at least one row is selected
        $("#btnExcel").click(function () {

