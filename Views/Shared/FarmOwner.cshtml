@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - FarmOwner</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet" />

    <link href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" rel="stylesheet" />

    <link href="~/Content/CSS/FarmOwner.css" rel="stylesheet" />

    @RenderSection("styles", required: false)
</head>

<body>

    <!-- ========== SIDEBAR ========== -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <i class="fas fa-leaf"></i>
            <span>FarmOwner</span>
        </div>

        <ul class="list-unstyled components">

            <li>
                <a href="@Url.Action("Index","Dashboard")" class="nav-link">
                    <i class="fas fa-chart-line me-2"></i> Dashboard
                </a>
            </li>

            <li>
                <a href="@Url.Action("Index","FarmProfile")" class="nav-link">
                    <i class="fas fa-home me-2"></i> Farm Profile Management
                </a>
            </li>

            <li>
                <a href="@Url.Action("Index","Service")" class="nav-link active">
                    <i class="fas fa-toolbox me-2"></i> Service Management
                </a>
            </li>

            <li>
                <a href="@Url.Action("Index","Package")" class="nav-link">
                    <i class="fas fa-box-open me-2"></i> Farm Package Management
                </a>
            </li>

            <li>
                <a href="@Url.Action("Index","Booking")" class="nav-link">
                    <i class="fas fa-calendar-check me-2"></i> Farm Booking Management
                </a>
            </li>

            <li>
                <a href="@Url.Action("Index","Payment")" class="nav-link">
                    <i class="fas fa-indian-rupee-sign me-2"></i> Payment Management
                </a>
            </li>

            <!-- REPORT DROPDOWN -->
            <li>
                <a href="#reportSubmenu"
                   data-bs-toggle="collapse"
                   class="dropdown-toggle nav-link">
                    <i class="fas fa-chart-column me-2"></i> Report
                </a>

                <ul class="collapse list-unstyled ps-4" id="reportSubmenu">

                    <li>
                        <a href="@Url.Action("RevenueReport","Report")" class="nav-link">
                            <i class="fas fa-money-bill-trend-up me-2"></i> Revenue Report
                        </a>
                    </li>

                    <li>
                        <a href="@Url.Action("BookingReport","Report")" class="nav-link">
                            <i class="fas fa-book-open me-2"></i> Booking Report
                        </a>
                    </li>

                </ul>
            </li>

            <li>
                <a href="@Url.Action("Index","Support")" class="nav-link">
                    <i class="fas fa-headset me-2"></i> Interaction & Support
                </a>
            </li>

        </ul>
    </nav>

    <div class="overlay"></div>

    <!-- ========== MAIN CONTENT ========== -->
    <div class="main-content">

        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">

                <!-- Mobile Hamburger -->
                <button type="button" id="sidebarCollapse" class="btn btn-sm d-lg-none me-2">
                    <i class="fas fa-bars fa-lg text-secondary"></i>
                </button>

                <h5 class="mb-0 ms-3 fw-bold text-secondary">
                    @ViewBag.Title
                </h5>

                <ul class="nav navbar-nav ms-auto align-items-center">

                    <!-- Notification -->
                    <li class="nav-item me-3">
                        <a class="nav-link position-relative" href="#">
                            <i class="fas fa-bell fa-lg text-secondary"></i>
                        </a>
                    </li>

                    <!-- Profile Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                           href="#"
                           data-bs-toggle="dropdown">

                            <span class="fw-bold">Farm Owner</span>

                            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center"
                                 style="width:35px;height:35px;">
                                FO
                            </div>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2">

                            <li>
                                @Html.ActionLink("My Profile", "Profile", "Account", null,
                                new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Subscription", "Subscription", "Account", null,
                                new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Password", "ChangePassword", "Account", null,
                                new { @class = "dropdown-item" })
                            </li>

                            <li>
                                @Html.ActionLink("Bank Account", "BankAccount", "Account", null,
                                new { @class = "dropdown-item" })
                            </li>

                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                @Html.ActionLink("Logout", "Logout", "Account", null,
                                    new { @class = "dropdown-item text-danger fw-bold" })
                            </li>

                        </ul>
                    </li>


                </ul>
            </div>
        </nav>

        <!-- Page Body -->
        <div class="container-fluid p-4">
            @RenderBody()
        </div>

    </div>


    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/Content/js/FarmOwner.js"></script>

    @RenderSection("scripts", required: false)

</body>
</html>

