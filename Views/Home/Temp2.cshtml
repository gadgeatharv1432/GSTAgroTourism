
@{
    ViewBag.Title = "Temp2";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - AgroTrip India</title>
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- DataTables CSS -->
    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

    <link rel="stylesheet"
          href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css" />

    <!-- Datepicker -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/datepicker/0.6.5/datepicker.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
    <!-- SweetAlert -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link href="~/Content/CSS/Temp2.css" rel="stylesheet" />
    @Styles.Render("~/Content/CSS/Visitor.css")

</head>
<body>
    <div class="card mb-3">
        <div class="card-body">

            <div class="row g-2 align-items-end">

                <div class="col-md-2">
                    <label>Destination</label>
                    <input type="text" class="form-control" placeholder="Where to?">
                </div>

                <div class="col-md-2">
                    <label>Check-in</label>
                    <div class="position-relative">
                        <input type="text"
                               id="checkinDate"
                               class="form-control date-input"
                               placeholder="dd-mm-yyyy">
                        <i class="fa fa-calendar calendar-icon"></i>
                    </div>
                </div>

                <div class="col-md-2">
                    <label>Check-out</label>
                    <div class="position-relative">
                        <input type="text"
                               id="checkoutDate"
                               class="form-control date-input"
                               placeholder="dd-mm-yyyy">
                        <i class="fa fa-calendar calendar-icon"></i>
                    </div>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        <i class="fa fa-search"></i> Search
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="date-filter">

        <label>Date range picker</label>

        <input type="text"
               id="dateRange"
               class="form-control"
               placeholder="Select Date Range" />

        <input type="hidden" id="startDate" />
        <input type="hidden" id="endDate" />

    </div>

    Toast alerts :-
    <div id="toastContainer" class="toast-container"></div> @*Use this line also when you copy toaster code*@

    <button type="button"
            class="btn btn-outline-success btn-rounded"
            onclick="showToast('Used For Submit & Save','success')">
        Toastwer01
    </button>
    <button type="button" class="btn btn-outline-danger btn-rounded" onclick="showToast('Used For Cancel & Error','error')">
        Toaster 02
    </button>
    <button type="button" class="btn btn-outline-warning btn-rounded" onclick="showToast('Used For Cancel & Error','warning')">
        Toaster 03
    </button>
    <button type="button" class="btn btn-outline-info btn-rounded" onclick="showToast('Used For Cancel & Error','info')">
        Toaster 04
    </button>
    <button type="button" class="btn btn-outline-dark btn-rounded" onclick="showToast('Used For Cancel & Error','loading')">
        Toaster 05
    </button>

    Sweet alerts :-

    <button class="btn btn-outline-success btn-rounded" onclick="showSuccess('Saved Successfully')">
        Success
    </button>

    <button class="btn btn-outline-danger btn-rounded" onclick="showError('Something went wrong')">
        Error
    </button>

    <button class="btn btn-outline-warning btn-rounded" onclick="showWarning('Check input')">
        Warning
    </button>

    <button class="btn btn-outline-info btn-rounded" onclick="showInfo('Information message')">
        Info
    </button>

    <button class="btn btn-outline-dark btn-rounded" onclick="showLoading('Processing...')">
        Loading
    </button>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Datepicker -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/datepicker/0.6.5/datepicker.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    <script src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>

        $(document).ready(function () {

            $('#checkinDate').datepicker({
                format: 'dd-mm-yyyy',
                autoHide: true
            });

            $('#checkoutDate').datepicker({
                format: 'dd-mm-yyyy',
                autoHide: true
            });

        });

        $(function () {

            $('#dateRange').daterangepicker({

                autoUpdateInput: false,

                showDropdowns: true,

                ranges: {

                    'Today': [moment(), moment()],

                    'Yesterday': [
                        moment().subtract(1, 'days'),
                        moment().subtract(1, 'days')
                    ],

                    'Last 7 Days': [
                        moment().subtract(6, 'days'),
                        moment()
                    ],

                    'Last 30 Days': [
                        moment().subtract(29, 'days'),
                        moment()
                    ],

                    'This Month': [
                        moment().startOf('month'),
                        moment().endOf('month')
                    ],

                    'Last Month': [
                        moment().subtract(1, 'month').startOf('month'),
                        moment().subtract(1, 'month').endOf('month')
                    ]

                },

                locale: {
                    cancelLabel: 'Clear'
                }

            });

            $('#dateRange').on('apply.daterangepicker', function (ev, picker) {

                $(this).val(

                    picker.startDate.format('DD/MM/YYYY')
                    +
                    ' - ' +
                    picker.endDate.format('DD/MM/YYYY')

                );

                $('#startDate').val(picker.startDate.format('YYYY-MM-DD'));

                $('#endDate').val(picker.endDate.format('YYYY-MM-DD'));

            });

            $('#dateRange').on('cancel.daterangepicker', function () {

                $(this).val('');

            });

        });

    </script>
    <script>
        function showLoading(title, message) {

            Swal.fire({

                title: title,

                html: `

<div class="modern-loader">

<div class="loader-ring"></div>

<div class="loader-title">
${title}
</div>

<div class="loader-text">
${message}
<span class="dots"></span>
</div>

</div>

`,

                showConfirmButton: false,

                allowOutsideClick: false,

                background: "#ffffff",

                width: 400

            });

            // auto close after 1 second
            setTimeout(function () {

                Swal.close();

            }, 1000);

        }
        function showToast(message, type = "info") {

            let container = document.getElementById("toastContainer");

            let toast = document.createElement("div");

            toast.className = "custom-toast toast-" + type;

            let icon = "fa-circle-info";

            if (type === "success") icon = "fa-check";
            if (type === "error") icon = "fa-xmark";
            if (type === "warning") icon = "fa-exclamation";
            if (type === "info") icon = "fa-circle-info";
            if (type === "loading") icon = "fa-spinner fa-spin";

            toast.innerHTML = `

<div class="toast-icon">

<i class="fa-solid ${icon}"></i>

</div>

<div>

${message}

</div>

<div class="toast-close">

<i class="fa-solid fa-xmark"></i>

</div>

<div class="toast-progress"></div>

`;

            container.appendChild(toast);

            setTimeout(() => {

                toast.style.opacity = "0";

                setTimeout(() => {
                    toast.remove();
                }, 300);

            }, 1500);

            toast.querySelector(".toast-close").onclick = function () {

                toast.remove();

            }

        }
    </script>
    <script>

        // SUCCESS
        function showSuccess(message) {

            Swal.fire({

                icon: 'success',

                title: 'Success',

                text: message,

                confirmButtonColor: '#28a745'

            });

        }

        // ERROR
        function showError(message) {

            Swal.fire({

                icon: 'error',

                title: 'Error',

                text: message,

                confirmButtonColor: '#dc3545'

            });

        }

        // WARNING
        function showWarning(message) {

            Swal.fire({

                icon: 'warning',

                title: 'Warning',

                text: message,

                confirmButtonColor: '#ffc107'

            });

        }

        // INFO
        function showInfo(message) {

            Swal.fire({

                icon: 'info',

                title: 'Information',

                text: message,

                confirmButtonColor: '#0dcaf0'

            });

        }
    </script>
</body>
</html>
